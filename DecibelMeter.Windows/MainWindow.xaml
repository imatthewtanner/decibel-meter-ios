<Window
    x:Class="DecibelMeter.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:oxy="http://oxyplot.org/wpf"
    Title="Decibel Meter"
    Width="800"
    Height="800"
    Icon="Assets/DecibelMeter.ico"
    Background="White"
    WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Status Bar -->
        <TextBlock Grid.Row="0" Text="{Binding StatusMessage}" Background="#F0F0F0" Padding="10" FontSize="12" TextWrapping="Wrap"/>

        <TabControl Grid.Row="1">
            <!-- Meter Tab -->
            <TabItem Header="Meter">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Controls -->
                    <StackPanel Grid.Column="0" Margin="20" VerticalAlignment="Top">
                        <TextBlock Text="Current Level" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding CurrentLevel, StringFormat=F1}" FontSize="72" FontWeight="Bold" Foreground="#007ACC" HorizontalAlignment="Center"/>
                        <TextBlock Text="dB" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                        
                        <Grid Margin="0,20,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Average:" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="{Binding AverageLevel, StringFormat=F1}" Foreground="#007ACC" FontSize="16" Margin="0,0,0,10"/>
                                <TextBlock Text="Peak:" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="{Binding PeakLevel, StringFormat=F1}" Foreground="#F44336" FontSize="16" Margin="0,0,0,10"/>
                                <TextBlock Text="Duration:" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="{Binding Duration, StringFormat=hh\\:mm\\:ss}" FontSize="14" Margin="0,0,0,20"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                            <Button Content="Start" Command="{Binding StartMeasurementCommand}" Padding="20,10" Margin="5" Background="#007ACC" Foreground="White" FontWeight="Bold"/>
                            <Button Content="Stop" Command="{Binding StopMeasurementCommand}" Padding="20,10" Margin="5" Background="#F44336" Foreground="White" FontWeight="Bold"/>
                        </StackPanel>

                        <CheckBox IsChecked="{Binding EnableAlerts}" Content="Enable Alerts" Margin="0,20,0,10" FontWeight="Bold"/>
                        
                        <Button Content="Export Data" Command="{Binding ExportDataCommand}" Padding="15,10" Margin="5" Background="#4CAF50" Foreground="White" FontWeight="Bold" Width="180"/>
                    </StackPanel>

                    <!-- Right: Chart -->
                    <Border Grid.Column="1" Margin="10" Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                        <oxy:PlotView Model="{Binding LevelChart}" Margin="10"/>
                    </Border>
                </Grid>
            </TabItem>

            <!-- History Tab -->
            <TabItem Header="History">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="20,10,20,10" Orientation="Horizontal">
                        <TextBlock Text="{Binding SessionCount, StringFormat='Sessions: {0}'}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#666666" VerticalAlignment="Center"/>
                    </StackPanel>

                    <ListBox Grid.Row="1" ItemsSource="{Binding Sessions}" Margin="20,0,20,10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10" BorderThickness="0,0,0,1" BorderBrush="#EEEEEE">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding StartedAt, StringFormat='MM/dd/yyyy hh:mm tt'}" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Duration, StringFormat='Duration: {0:hh\\:mm\\:ss}'}" Foreground="#666666" FontSize="12"/>
                                            <TextBlock Text="{Binding MinimumLevel, StringFormat='Min: {0:F1} dB'}" Foreground="#666666" FontSize="11"/>
                                            <TextBlock Text="{Binding AverageLevel, StringFormat='Avg: {0:F1} dB'}" Foreground="#007ACC" FontSize="11"/>
                                            <TextBlock Text="{Binding PeakLevel, StringFormat='Peak: {0:F1} dB'}" Foreground="#F44336" FontSize="11"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Delete" Command="{Binding DataContext.DeleteSessionCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding .}" Padding="8,4" Background="#F44336" Foreground="White"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2" Margin="20,10,20,10" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Export All" Command="{Binding ExportSessionsCommand}" Padding="15,8" Margin="5" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
                        <Button Content="Clear All" Command="{Binding ClearAllCommand}" Padding="15,8" Margin="5" Background="#FF9800" Foreground="White" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Settings Tab -->
            <TabItem Header="Settings">
                <ScrollViewer>
                    <StackPanel Margin="20">
                        <TextBlock Text="Sound Level Settings" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                        <!-- Calibration -->
                        <GroupBox Header="Calibration" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="Calibration Offset (dB)" FontWeight="Bold" Margin="0,0,0,10"/>
                                <Slider Value="{Binding CalibrationOffset}" Minimum="-20" Maximum="20" Height="30" Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding CalibrationOffset, StringFormat='Offset: {0:F1} dB'}" Margin="0,0,0,10"/>
                                <TextBlock Text="Adjust to match readings from a reference meter" FontSize="11" Foreground="#666666" TextWrapping="Wrap"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Alerts -->
                        <GroupBox Header="Sound Level Alerts" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <CheckBox IsChecked="{Binding EnableSoundNotifications}" Content="Enable sound notifications" Margin="0,0,0,10" FontWeight="Bold"/>
                                <TextBlock Text="Alert Threshold (dB)" FontWeight="Bold" Margin="0,10,0,5"/>
                                <Slider Value="{Binding AlertThreshold}" Minimum="60" Maximum="100" Height="30" Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding AlertThreshold, StringFormat='Alert at: {0:F0} dB'}" Margin="0,0,0,10"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Appearance -->
                        <GroupBox Header="Appearance" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <CheckBox IsChecked="{Binding EnableDarkMode}" Content="Enable dark mode" Margin="0,0,0,10" FontWeight="Bold"/>
                                <Button Content="Apply Theme" Command="{Binding ToggleDarkModeCommand}" Padding="15,8" Background="#FF9800" Foreground="White" Width="120"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                            <Button Content="Save" Command="{Binding SaveSettingsCommand}" Padding="15,8" Margin="5" Background="#007ACC" Foreground="White" FontWeight="Bold"/>
                            <Button Content="Reset" Command="{Binding ResetToDefaultsCommand}" Padding="15,8" Margin="5" Background="#FF9800" Foreground="White" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
