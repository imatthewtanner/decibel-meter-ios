<Application
    x:Class="DecibelMeter.Windows.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Colors -->
            <Color x:Key="AccentColor">#007ACC</Color>
            <Color x:Key="BackgroundColor">#FFFFFF</Color>
            <Color x:Key="ForegroundColor">#000000</Color>
            <Color x:Key="BorderColor">#CCCCCC</Color>
            
            <!-- Brushes -->
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
            <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
            <SolidColorBrush x:Key="ForegroundBrush" Color="{StaticResource ForegroundColor}" />
            <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
            
            <!-- Sound Level Bands -->
            <SolidColorBrush x:Key="LowBandColor">#4CAF50</SolidColorBrush>
            <SolidColorBrush x:Key="ModerateBandColor">#FFC107</SolidColorBrush>
            <SolidColorBrush x:Key="HighBandColor">#FF9800</SolidColorBrush>
            <SolidColorBrush x:Key="VeryHighBandColor">#F44336</SolidColorBrush>
        </ResourceDictionary>
    </Application.Resources>
</Application>
